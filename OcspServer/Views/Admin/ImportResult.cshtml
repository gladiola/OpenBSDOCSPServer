@model OcspServer.Models.ImportResult
@{
    ViewData["Title"] = L["ImportResultPageTitle"];
}

<h1 class="h3 mb-4">@L["ImportResultHeading"]</h1>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card text-bg-success">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.Added</div>
                <div>@L["ImportResultAdded"]</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-bg-info">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.Updated</div>
                <div>@L["ImportResultUpdated"]</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card @(Model.Errors.Count > 0 ? "text-bg-danger" : "text-bg-secondary")">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.Errors.Count</div>
                <div>@L["ImportResultErrors"]</div>
            </div>
        </div>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">@L["ImportResultSource"]</dt>
    <dd class="col-sm-10">@Model.Source</dd>
    <dt class="col-sm-2">@L["ImportResultImportedAt"]</dt>
    <dd class="col-sm-10">@Model.ImportedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</dd>
    <dt class="col-sm-2">@L["ImportResultUnchanged"]</dt>
    <dd class="col-sm-10">@Model.Unchanged</dd>
</dl>

@if (Model.Errors.Count > 0)
{
    <h5 class="text-danger mt-3">@L["ImportResultErrors"]</h5>
    <ul class="list-group">
        @foreach (var err in Model.Errors)
        {
            <li class="list-group-item list-group-item-danger small">@err</li>
        }
    </ul>
}

<div class="mt-4">
    <a asp-controller="Admin" asp-action="Certificates" class="btn btn-primary">@L["ImportResultViewCertificates"]</a>
    <a asp-controller="Admin" asp-action="Import" class="btn btn-outline-secondary ms-2">@L["ImportResultImportMore"]</a>
</div>

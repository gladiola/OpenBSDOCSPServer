@model OcspServer.Controllers.DashboardViewModel
@{
    ViewData["Title"] = L["DashboardPageTitle"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">@L["DashboardHeading"]</h1>
    <a asp-controller="Admin" asp-action="Import" class="btn btn-primary">@L["DashboardImportData"]</a>
</div>

@if (Model.SignerExpiringSoon)
{
    <div class="alert alert-warning" role="alert">
        <strong>@L["WarningLabel"]</strong> @L["DashboardSignerExpiresOn"]
        <strong>@Model.SignerCertExpiry?.ToString("yyyy-MM-dd HH:mm UTC")</strong>.
        @L["DashboardRenewBeforeExpiry"]
    </div>
}

@if (string.IsNullOrEmpty(ViewBag.SignerInfo as string) == false)
{
    <div class="alert alert-danger" role="alert">@ViewBag.SignerInfo</div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-secondary">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.TotalCertificates</div>
                <div>@L["DashboardTotalCertificates"]</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.GoodCount</div>
                <div>@L["StatusGood"]</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.RevokedCount</div>
                <div>@L["StatusRevoked"]</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.UnknownCount</div>
                <div>@L["StatusUnknown"]</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">@L["DashboardCertificateStore"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@L["DashboardLastImport"]</dt>
                    <dd class="col-sm-7">
                        @(Model.LastImportTime.HasValue
                            ? Model.LastImportTime.Value.ToString("yyyy-MM-dd HH:mm:ss UTC")
                            : L["DashboardNever"].Value)
                    </dd>
                </dl>
                <a asp-controller="Admin" asp-action="Certificates" class="btn btn-outline-primary btn-sm mt-2">
                    @L["DashboardViewAllCertificates"]
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">@L["DashboardSignerCert"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@L["DashboardExpires"]</dt>
                    <dd class="col-sm-7">
                        @(Model.SignerCertExpiry.HasValue
                            ? Model.SignerCertExpiry.Value.ToString("yyyy-MM-dd HH:mm UTC")
                            : L["DashboardNotLoaded"].Value)
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@model OcspServer.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "OCSP Admin — Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Dashboard</h1>
    <a asp-controller="Admin" asp-action="Import" class="btn btn-primary">Import Data</a>
</div>

@if (Model.SignerExpiringSoon)
{
    <div class="alert alert-warning" role="alert">
        <strong>Warning:</strong> The OCSP signing certificate expires on
        <strong>@Model.SignerCertExpiry?.ToString("yyyy-MM-dd HH:mm UTC")</strong>.
        Renew it before it expires to avoid signing failures.
    </div>
}

@if (string.IsNullOrEmpty(ViewBag.SignerInfo as string) == false)
{
    <div class="alert alert-danger" role="alert">@ViewBag.SignerInfo</div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-secondary">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.TotalCertificates</div>
                <div>Total Certificates</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.GoodCount</div>
                <div>Good</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.RevokedCount</div>
                <div>Revoked</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="fs-2 fw-bold">@Model.UnknownCount</div>
                <div>Unknown</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Certificate Store</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Last Import</dt>
                    <dd class="col-sm-7">
                        @(Model.LastImportTime.HasValue
                            ? Model.LastImportTime.Value.ToString("yyyy-MM-dd HH:mm:ss UTC")
                            : "Never")
                    </dd>
                </dl>
                <a asp-controller="Admin" asp-action="Certificates" class="btn btn-outline-primary btn-sm mt-2">
                    View All Certificates
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">OCSP Signing Certificate</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Expires</dt>
                    <dd class="col-sm-7">
                        @(Model.SignerCertExpiry.HasValue
                            ? Model.SignerCertExpiry.Value.ToString("yyyy-MM-dd HH:mm UTC")
                            : "Not loaded")
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

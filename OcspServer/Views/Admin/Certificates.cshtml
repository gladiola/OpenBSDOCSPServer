@model OcspServer.Controllers.CertificateListViewModel
@using OcspServer.Models
@{
    ViewData["Title"] = L["CertificatesPageTitle"];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@L["CertificatesHeading"]</h1>
    <a asp-controller="Admin" asp-action="Import" class="btn btn-primary btn-sm">@L["NavImport"]</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="search" value="@Model.Search"
               class="form-control" placeholder="@L["CertificatesSearchPlaceholder"]" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">@L["SearchButton"]</button>
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a asp-controller="Admin" asp-action="Certificates" class="btn btn-link">@L["ClearButton"]</a>
        }
    </div>
</form>

<p class="text-muted small">
    @L["CertificatesShowingRange", (((Model.Page - 1) * Model.PageSize) + 1), Math.Min(Model.Page * Model.PageSize, Model.TotalCount), Model.TotalCount]
    @if (!string.IsNullOrEmpty(Model.Search)) { <span>@L["CertificatesMatchingSearch", Model.Search]</span> }
</p>

<div class="table-responsive">
    <table class="table table-sm table-hover">
        <thead class="table-dark">
            <tr>
                <th>@L["CertificatesSerial"]</th>
                <th>@L["CertificatesSubject"]</th>
                <th>@L["CertificatesStatus"]</th>
                <th>@L["CertificatesRevocationDate"]</th>
                <th>@L["CertificatesReason"]</th>
                <th>@L["CertificatesExpires"]</th>
                <th>@L["CertificatesSource"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cert in Model.Records)
            {
                <tr class="@(cert.Status == CertificateStatus.Revoked ? "table-danger" : cert.Status == CertificateStatus.Unknown ? "table-warning" : "")">
                    <td><code class="small">@cert.SerialNumber</code></td>
                    <td class="text-truncate" style="max-width:220px" title="@cert.SubjectDN">@cert.SubjectDN</td>
                    <td>
                        @switch (cert.Status)
                        {
                            case CertificateStatus.Good:
                                <span class="badge bg-success">@L["StatusGood"]</span>
                                break;
                            case CertificateStatus.Revoked:
                                <span class="badge bg-danger">@L["StatusRevoked"]</span>
                                break;
                            default:
                                <span class="badge bg-warning text-dark">@L["StatusUnknown"]</span>
                                break;
                        }
                    </td>
                    <td>@(cert.RevocationDate.HasValue ? cert.RevocationDate.Value.ToString("yyyy-MM-dd") : L["NotAvailableDash"].Value)</td>
                    <td>@(cert.Status == CertificateStatus.Revoked ? cert.RevocationReason.ToString() : L["NotAvailableDash"].Value)</td>
                    <td>@(cert.NotAfter == DateTime.MinValue ? L["NotAvailableDash"].Value : cert.NotAfter.ToString("yyyy-MM-dd"))</td>
                    <td class="small text-muted">@cert.ImportSource</td>
                    <td class="text-nowrap">
                        <a asp-controller="Admin" asp-action="Detail"
                           asp-route-id="@cert.Id" class="btn btn-outline-secondary btn-sm">@L["DetailButton"]</a>
                        @if (cert.Status != CertificateStatus.Revoked)
                        {
                            <a asp-controller="Admin" asp-action="Revoke"
                               asp-route-id="@cert.Id" class="btn btn-outline-danger btn-sm ms-1">@L["RevokeButton"]</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-controller="Admin" asp-action="Certificates"
                       asp-route-page="@p" asp-route-search="@Model.Search">@p</a>
                </li>
            }
        </ul>
    </nav>
}

@model ErrorViewModel
@{
    ViewData["Title"] = L["ErrorTitle"];
}

<h1 class="text-danger">@L["ErrorHeading"]</h1>
<h2 class="text-danger">@L["ErrorProcessingRequest"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@L["ErrorRequestIdLabel"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@L["ErrorDevelopmentModeHeading"]</h3>
<p>
    @L["ErrorDevelopmentModeBody"]
</p>
<p>
    <strong>@L["ErrorDevelopmentWarning"]</strong>
    @L["ErrorSensitiveInfoWarning"]
    @L["ErrorLocalDebugInstructions"]
</p>

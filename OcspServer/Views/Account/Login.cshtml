@{
    ViewData["Title"] = L["LoginTitle"];
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-sm-8 col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">@L["LoginHeading"]</h4>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post"
                      asp-controller="Account" asp-action="Login"
                      asp-route-returnUrl="@ViewData["ReturnUrl"]">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="username" class="form-label">@L["LoginUsername"]</label>
                        <input type="text" id="username" name="username"
                               class="form-control" autocomplete="username"
                               autofocus required />
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">@L["LoginPassword"]</label>
                        <input type="password" id="password" name="password"
                               class="form-control" autocomplete="current-password" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@L["LoginSignIn"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

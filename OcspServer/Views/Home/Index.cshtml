@{
    ViewData["Title"] = L["HomeTitle"];
}

<div class="text-center mt-4">
    <h1 class="display-5">@L["HomeHeading"]</h1>
    <p class="lead text-muted">@L["HomeLead"]</p>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">@L["HomeEndpointHeader"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">POST</dt>
                    <dd class="col-sm-9"><code>/ocsp</code> — @L["HomePostDescription"] <code>application/ocsp-request</code></dd>
                    <dt class="col-sm-3">GET</dt>
                    <dd class="col-sm-9"><code>/ocsp/{base64url-encoded-request}</code></dd>
                </dl>
                <p class="mt-2 mb-0 text-muted small">
                    @L["HomeResponsesDescription"] <code>application/ocsp-response</code>.
                    @L["HomeNoAuthDescription"]
                </p>
            </div>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary">@L["HomeAdminDashboardButton"]</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">@L["NavAdminLogin"]</a>
        }
    </div>
</div>

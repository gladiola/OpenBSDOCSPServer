{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "FeatureFlags": {
    "EnableSession": true,
    "EnableSecurityHeaders": true,
    "EnableMtls": false,
    "EnableAdminAuth": true,
    "EnableOcspNonce": true,
    "EnableEntraIdAuth": false,
    "EnableIndexTxtWatch": false
  },

  "OcspServer": {
    "PfxPath": null,
    "PfxPassword": null,
    "ResponderCertPath": "/etc/ocsp/responder.crt",
    "SigningKeyPath": "/etc/ocsp/responder.key",
    "SigningKeyPassword": null,
    "NextUpdateHours": 24,
    "AllowNonce": true,
    "RequireNonce": false,
    "MaxNonceSizeBytes": 32,
    "AllowGetRequests": true,
    "AllowPostRequests": true
  },

  "AdminAuth": {
    "AdminUsername": "admin",
    "AdminPasswordHash": "",
    "SessionTimeoutMinutes": 30
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": null,
    "AdminGroupId": null,
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-oidc"
  },

  "Ingestion": {
    "IndexTxtWatchPath": null,
    "PollingIntervalMinutes": 0,
    "LocalOcspResponderUrl": null,
    "DatabasePath": "ocsp.db"
  }
}
